# ===========================================================================
# PDF-Papers AI Agent — environment configuration
# Copy to `.env` (the app auto-loads it) and edit as needed:
#     cp .env.example .env
# ===========================================================================

# --- MongoDB (chunk/doc metadata, provenance) ------------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=csai415
MONGO_COLLECTION=chunks

# --- Qdrant (dense vector store) -------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=chunks

# --- Neo4j (knowledge graph) -----------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=csai415pass
NEO4J_DATABASE=neo4j

# --- Models ----------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- D4 small language model (answer generation) ---------------------------
# SLM_BACKEND: extractive (grounded, no model, safe CPU default) | base | tuned
SLM_BACKEND=extractive
SLM_BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
# SLM_ADAPTER_DIR defaults to artifacts/slm_lora (set by train_slm.py)

# --- API -------------------------------------------------------------------
API_BASE_URL=http://localhost:8000

# Force UTF-8 stdout so Windows consoles don't crash on box-drawing characters.
PYTHONUTF8=1
